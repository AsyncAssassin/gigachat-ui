# Copy this file to .env and set real values only on your local machine.
# Never commit real keys or tokens.
GIGACHAT_AUTH_KEY=__SET_LOCALLY__
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Optional: absolute path to trusted CA certificate in PEM format for backend TLS validation.
# GIGACHAT_CA_CERT_PATH=/absolute/path/to/corporate-ca.pem
