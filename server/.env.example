# Local backend proxy env example.
# Copy to server/.env and set real values only locally.
PORT=8787
GIGACHAT_AUTH_KEY=__SET_LOCALLY__
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
# Optional: absolute path to trusted CA certificate in PEM format.
# Use this when your network performs TLS interception and Node cannot verify upstream cert chain.
# GIGACHAT_CA_CERT_PATH=/absolute/path/to/corporate-ca.pem
